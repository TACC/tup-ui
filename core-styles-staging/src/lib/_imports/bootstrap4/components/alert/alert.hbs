{{#groups}}
  <section>
    <h3>{{title}}</h3>
    {{#types}}
      <div
        class="
          alert alert-{{type}}
          {{#if dismissible}}alert-dismissible fade show{{/if}}
          {{cMessageClasses}}
        "
        role="alert"
      >
        {{#if heading}}<h4 class="alert-heading">{{heading}}</h4>{{/if}}
        {{{content}}}
        {{#if dismissible}}
          <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        {{/if}}
      </div>
    {{/types}}
  </section>
{{/groups}}
